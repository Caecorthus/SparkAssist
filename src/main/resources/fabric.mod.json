{
  "schemaVersion": 1,
  "id": "sparkassist",
  "version": "${version}",
  "name": "SparkAssist",
  "description": "Client-side accessibility helpers for Spark wathe sessions.",
  "authors": [
    "Caecorthus"
  ],
  "license": "AGPL-3.0-only",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.caecorthus.sparkassist.client.SparkAssistClient"
    ]
  },
  "mixins": [
    {
      "config": "sparkassist.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "wathe": "*",
    "noellesroles": "*",
    "sparkwitch": "*",
    "sparktraits": "*",
    "sparkstrength": "*"
  }
}
